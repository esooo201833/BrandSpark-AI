# Database - PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/brandspark

# OpenAI API
OPENAI_API_KEY=your_openai_key_here
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Stripe Payment
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_key_here

# Email Configuration (Gmail SMTP)
GMAIL_USER=your-email@gmail.com
GMAIL_PASSWORD=your-app-password
GMAIL_FROM=noreply@brandspark.com

# NextAuth Configuration
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-random-secret-key-here-min-32-chars
GOOGLE_ID=your-google-oauth-id
GOOGLE_SECRET=your-google-oauth-secret

# API Rate Limiting & Performance
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60
CACHE_TTL=3600

# Database Connection Pooling
DB_POOL_SIZE=10
DB_IDLE_TIMEOUT=30000

# Perfect Money (Optional alternative payment)
PERFECT_MONEY_ACCOUNT_ID=your-account-id
PERFECT_MONEY_API_KEY=your-api-key

# PayPal (Optional alternative payment)
PAYPAL_CLIENT_ID=your-client-id
PAYPAL_CLIENT_SECRET=your-client-secret
PAYPAL_MODE=sandbox

# App Settings
NODE_ENV=development
DEBUG=false

# Redis (Optional, for caching)
REDIS_URL=redis://localhost:6379

PRISMA_CLIENT_ENGINE_TYPE=binary
